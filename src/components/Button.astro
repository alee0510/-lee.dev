---
interface Props {
  text?: string;
  fill?: string;
  stroke?: string;
  strokeWidth?: string | number;
  textColor?: string;
  fontSize?: string | number;
  fontFamily?: string;
  padding?: string;
  hoverTextColor?: string;
  hoverFill?: string;
  class?: string;
}

const {
  text = 'button',
  fill = '#f56020',
  stroke = '#1a1a1a',
  strokeWidth = '1',
  textColor = '#1a1a1a',
  fontSize = '1rem',
  fontFamily = 'Space Mono, monospace',
  padding = '1rem 4rem',
  hoverTextColor = '#FAFAFA',
  hoverFill = '#1a1a1a',
  class: className,
  ...props
} = Astro.props;

const styleVariables = {
  '--btn-fill': fill,
  '--btn-hover-fill': hoverFill,
  '--btn-stroke': stroke,
  '--btn-stroke-width': strokeWidth,
  '--btn-text-color': textColor,
  '--btn-hover-text-color': hoverTextColor,
  '--btn-font-size': fontSize,
  '--btn-padding': padding,
};
---

<div class=`btn ${className}` style={styleVariables} {...props}>
  <svg
    viewBox="0 0 340 56"
    preserveAspectRatio="none"
    class="btn__bg"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      class="btn__path"
      d="M 14,0 L 334,0 Q 340,0 340,6 L 340,39 Q 340,42 337,45 L 329,53 Q 326,56 323,56 L 6,56 Q 0,56 0,50 L 0,17 Q 0,14 3,11 L 11,3 Q 14,0 14,0 Z"
    ></path>
  </svg>
  <span class="btn__text">
    {text}
  </span>
</div>

<style>
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--btn-padding);
    cursor: pointer;
    isolation: isolate;
  }

  .btn__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }

  .btn__text {
    font-size: var(--btn-font-size);
    color: var(--btn-text-color);
    letter-spacing: 0.08rem;
    white-space: nowrap;
    text-align: center;
    line-height: 1;
    pointer-events: none;
    transition: color 0.3s ease;
  }

  .btn__path {
    fill: var(--btn-fill);
    stroke: var(--btn-stroke);
    stroke-width: var(--btn-stroke-width);
    vector-effect: non-scaling-stroke;
    transition:
      fill 0.3s ease,
      stroke 0.3s ease;
  }

  .btn:hover .btn__path {
    fill: var(--btn-hover-fill);
  }

  .btn:hover .btn__text {
    color: var(--btn-hover-text-color);
  }
</style>
